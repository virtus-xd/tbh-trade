# --- Supabase / Postgres ---
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
SUPABASE_URL=https://[PROJECT].supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # yalnız worker/server tarafı

# --- Steam ---
STEAM_APP_ID=3678970
STEAM_CURRENCY=1                   # 1 = USD

# --- Fiyat sağlayıcı (hibrit) ---
PRICE_PROVIDER=steam_direct        # steam_direct | thirdparty
THIRDPARTY_API_KEY=                # ThirdPartyProvider için (örn. steamwebapi)
INGEST_DAILY_BUDGET=4000           # günlük maks Steam isteği (kaba sınır)
INGEST_MIN_DELAY_MS=3500           # priceoverview (çok limitli) istekler arası taban gecikme
INGEST_ENUMERATE_DELAY_MS=1500     # search/render (ucuz) istekler arası taban gecikme
PRICE_VOLUME_THRESHOLD=5           # median kullanmak için min hacim
INGEST_PRICEOVERVIEW_LIMIT=0       # ingest:once'ta median/volume çekilecek öncelikli item sayısı (0=atla)
INGEST_MAX_PAGES=0                 # ingest:once sayfa sınırı (0=tümü; her sayfa ~10 liste)

# --- Cron / güvenlik ---
INGEST_CRON_SECRET=                # /api/ingest tetikleyici doğrulaması

# --- Genel ---
NEXT_PUBLIC_SITE_URL=https://localhost:3000
GAME_VERSION=1.00.06               # seed/datamine damgası
